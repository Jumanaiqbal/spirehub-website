# Spire Hub — Odoo Meeting Rooms integration
# Copy this file to .env and add your real credentials there (never commit .env)

ODOO_URL=https://spire-test1.odoo.com
ODOO_DB=spire-test1
ODOO_USERNAME=your-odoo-email@example.com
ODOO_API_KEY=your-api-key-here

ODOO_ROOM_MODEL=room.room
ODOO_BOOKING_MODEL=room.booking
ODOO_ROOM_FIELDS=id,name,short_code,description,room_booking_url,room_background_image,is_available
ODOO_BOOKING_FIELDS=id,name,room_id,start_datetime,stop_datetime

# Hub timezone — Odoo API uses UTC; website shows Bahrain local time
ODOO_TIMEZONE=Asia/Bahrain

# Bank transfer details (shown to guests after booking — VITE_ prefix required for frontend)
VITE_SPIRE_BANK_ACCOUNT_NAME=SPIRE HUB W.L.L
VITE_SPIRE_BANK_IBAN=your-iban-here
VITE_SPIRE_BANK_ACCOUNT_NUMBER=your-account-number
VITE_SPIRE_BANK_NAME=Bahrain Islamic Bank
VITE_SPIRE_BANK_SWIFT=BIBBBHBM
VITE_SPIRE_PAYMENT_DEADLINE_HOURS=24

# AFS (Arab Financial Services) payment gateway — Copy&Pay / OPPWA
AFS_ENTITY_ID=your-entity-id-here
AFS_ACCESS_TOKEN=your-access-token-here
AFS_BASE_URL=https://eu-test.oppwa.com
AFS_CURRENCY=BHD

# Set to "true" once your BENEFIT/AFS merchant account is approved and live.
# Until then, the site only offers bank transfer (no online card payment
# button shown).
VITE_AFS_PAYMENTS_ENABLED=false

# Automated invoicing — on successful AFS payment, an invoice is created,
# posted, and paid against these Odoo records. Defaults match Spire Hub's
# Odoo setup; override only if these records differ in your database.
# Also requires a one-time Odoo Automation Rule (created via API, see
# server/odoo/invoices.ts) that emails the invoice PDF once it's marked paid.
ODOO_INVOICE_JOURNAL_ID=1
ODOO_AFS_JOURNAL_ID=15
ODOO_AFS_PAYMENT_METHOD_LINE_ID=19
ODOO_SALE_TAX_ID=1
ODOO_MEETING_ROOM_PRODUCT_ID=511
ODOO_WORKSHOP_ROOM_PRODUCT_ID=874
